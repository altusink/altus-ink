# Altus Ink - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Core Application
# ===========================================

# Database connection (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/altusink

# Session encryption key (generate a random 32+ character string)
SESSION_SECRET=your-super-secret-session-key-here

# Application URL (without protocol, e.g., altusink.io)
APP_URL=altusink.io

# ===========================================
# REQUIRED - Stripe Payment Processing
# ===========================================

STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# ===========================================
# RECOMMENDED - Email Notifications (SMTP)
# ===========================================

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@altusink.io
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="ALTUSINK.IO <noreply@altusink.io>"

# ===========================================
# OPTIONAL - WhatsApp Notifications (Z-API)
# ===========================================

ZAPI_INSTANCE_ID=your-instance-id
ZAPI_TOKEN=your-zapi-token

# ===========================================
# OPTIONAL - Docker Compose (for VPS deployment)
# ===========================================

DB_PASSWORD=your-database-password

# ===========================================
# PRODUCTION SETTINGS
# ===========================================

NODE_ENV=production
PORT=5000
