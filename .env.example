/**
 * ALTUS INK - ENVIRONMENT CONFIGURATION
 * Complete documentation of all environment variables
 * 
 * Copy this file to .env and fill in your values
 */

# =============================================================================
# APPLICATION
# =============================================================================

# Application URL (used for generating links)
APP_URL=http://localhost:5000

# Node environment (development | staging | production)
NODE_ENV=development

# Server port
PORT=5000

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-minimum-32-characters

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_SECRET=your-encryption-secret-minimum-32-characters

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/altusink

# Connection pool settings (optional)
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Replit Auth (if using Replit)
REPLIT_DOMAINS=your-replit-domain.replit.dev

# JWT settings
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# Session settings
SESSION_MAX_AGE=86400000

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================

# Stripe API keys
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secrets
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# Platform fee percentage (e.g., 15 for 15%)
PLATFORM_FEE_PERCENT=15

# Minimum payout amount in cents (e.g., 5000 for €50)
MIN_PAYOUT_AMOUNT=5000

# =============================================================================
# EMAIL (choose one provider)
# =============================================================================

# Email provider: sendgrid | resend | smtp
EMAIL_PROVIDER=sendgrid

# SendGrid
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxx...

# Resend
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxx...

# SMTP (fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# From email address
EMAIL_FROM=bookings@altusink.com
EMAIL_FROM_NAME=Altus Ink

# =============================================================================
# WHATSAPP BUSINESS API
# =============================================================================

# WhatsApp Business API credentials
# Get from: https://developers.facebook.com/apps
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token
WHATSAPP_API_VERSION=v18.0

# =============================================================================
# SMS (Twilio)
# =============================================================================

# Twilio credentials
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# FILE STORAGE (choose one provider)
# =============================================================================

# Storage provider: cloudinary | s3 | local
STORAGE_PROVIDER=cloudinary

# Cloudinary
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=altusink-uploads

# Local storage (development only)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# =============================================================================
# AI ORACLE (Multi-Provider)
# =============================================================================

# Primary AI provider: gemini | claude | openai | groq
AI_PRIMARY_PROVIDER=gemini

# Google AI (Gemini)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-key

# Anthropic (Claude)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key

# OpenAI
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key

# Groq
# Get from: https://console.groq.com
GROQ_API_KEY=your-groq-key

# Together AI
# Get from: https://api.together.xyz
TOGETHER_API_KEY=your-together-key

# AI settings
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# =============================================================================
# CHATWOOT (Customer Support)
# =============================================================================

# Chatwoot integration
# Get from: https://app.chatwoot.com/settings/inboxes
CHATWOOT_API_KEY=your-chatwoot-api-key
CHATWOOT_ACCOUNT_ID=your-account-id
CHATWOOT_INBOX_ID=your-inbox-id
CHATWOOT_BASE_URL=https://app.chatwoot.com

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Sentry error tracking
# Get from: https://sentry.io/settings/projects
SENTRY_DSN=https://xxx@sentry.io/xxx

# PostHog analytics
# Get from: https://posthog.com
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://app.posthog.com

# Google Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# RATE LIMITING
# =============================================================================

# Rate limit settings
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Auth rate limits
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# =============================================================================
# CORS & SECURITY
# =============================================================================

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5000,https://altusink.com

# Security headers
HELMET_ENABLED=true
CSRF_ENABLED=true

# =============================================================================
# CACHING (Redis)
# =============================================================================

# Redis connection (optional, for caching)
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds
CACHE_TTL=3600

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Feature toggles
FEATURE_WHATSAPP_ENABLED=true
FEATURE_AI_ORACLE_ENABLED=true
FEATURE_TWO_FACTOR_ENABLED=true
FEATURE_SUBSCRIPTIONS_ENABLED=true

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Log format: json | pretty
LOG_FORMAT=pretty

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Disable rate limiting in development
DEV_DISABLE_RATE_LIMIT=true

# Enable debug mode
DEBUG=false

# Seed database on startup
AUTO_SEED=false
